<%- include('partials/header') %>

<main>
  <h1><%= title %></h1>
  <p>Here are our upcoming service projects:</p>
  <ul>
    <% projects.forEach(project => { %>
      <li>
        <strong><%= new Date(project.date).toDateString() %></strong>: 
        <a href="/project/<%= project.project_id %>"><%= project.title %></a> 
        (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
        <br>
        <em><%= project.location %></em>
        <p><%= project.description %></p>
      </li>
    <% }); %>
  </ul>
</main>

<%- include('partials/footer') %>
 